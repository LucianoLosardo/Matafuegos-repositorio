# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=8000
ENVIRONMENT=development

# --- BASE DE DATOS (Supabase / PostgreSQL) ---
# Reemplaza con tus credenciales cuando crees el proyecto en Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# --- SEGURIDAD Y JWT (Ciberseguridad) ---
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=tu_clave_secreta_super_segura_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- INTELIGENCIA ARTIFICIAL ---
# Aquí irá tu clave de OpenAI o Anthropic
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- CONFIGURACIÓN DE LA EMPRESA ---
COMPANY_NAME="Seguridad Industrial Total"
# Días de antelación para avisar sobre el vencimiento de un matafuego
EXPIRATION_ALERT_DAYS=30
